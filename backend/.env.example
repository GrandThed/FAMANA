# Copy to .env for local development. On Railway these are set as service variables.

# PostgreSQL connection string.
# Railway provides this automatically as DATABASE_URL when you add a Postgres plugin.
DATABASE_URL=postgres://user:password@localhost:5432/mmo

# Shared secret that Roblox servers must send in the X-Api-Key header.
# Generate a long random value (e.g. `openssl rand -hex 32`) and set the SAME
# value in your Roblox server's config (a ModuleScript, never a LocalScript).
API_KEY=change-me-to-a-long-random-secret

# Port the API listens on. Railway sets PORT automatically; default for local.
PORT=3000

# --- Admin dashboard (see docs/ADMIN_DASHBOARD.md) --------------------------
# Password for the web admin panel at /admin. Separate from API_KEY on purpose
# (API_KEY is shared with Roblox servers). Leave unset to disable the panel.
ADMIN_PASSWORD=change-me-to-a-strong-password

# Secret used to sign admin session cookies. Generate a long random value
# (e.g. `openssl rand -hex 32`). Falls back to API_KEY if unset, but set a
# dedicated one in production.
ADMIN_SESSION_SECRET=change-me-to-a-long-random-secret

# Set to "production" on Railway so session cookies get the Secure flag.
NODE_ENV=development
